<?xml version='1.0' encoding='utf-8'?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/background">
    <TextView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="16dp" android:gravity="center" android:text="←" android:textColor="@color/on_surface_variant" android:textSize="20sp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />
    <androidx.core.widget.NestedScrollView android:layout_width="0dp" android:layout_height="0dp" android:fillViewport="true" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@+id/btnBack">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="32dp" android:paddingTop="24dp" android:paddingEnd="32dp" android:paddingBottom="32dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:text="Chúng tôi nên gọi bạn là gì?" android:textColor="@color/on_surface" android:textSize="32sp" android:textStyle="bold" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:text="Một cái tên thân thuộc sẽ giúp hành trình cá nhân hoá của bạn tốt hơn." android:textColor="@color/on_surface_variant" android:textSize="16sp" />
            <FrameLayout android:layout_width="144dp" android:layout_height="144dp" android:layout_gravity="center_horizontal" android:layout_marginTop="44dp">
                <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_avatar_placeholder" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="📷" android:textColor="@color/primary" android:textSize="30sp" />
                <TextView android:layout_width="40dp" android:layout_height="40dp" android:layout_gravity="bottom|end" android:background="@drawable/bg_circle_primary" android:gravity="center" android:text="+" android:textColor="@color/on_primary" android:textSize="22sp" android:textStyle="bold" />
            </FrameLayout>
            <EditText android:id="@+id/etDisplayName" android:layout_width="match_parent" android:layout_height="64dp" android:layout_marginTop="44dp" android:background="@drawable/bg_input_surface" android:hint="Minh" android:paddingStart="24dp" android:paddingEnd="24dp" android:textColor="@color/on_surface" android:textColorHint="@color/outline" android:textSize="20sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center" android:text="Tên này sẽ hiển thị trên bảng xếp hạng và các thông báo khích lệ hằng ngày." android:textColor="@color/on_surface_variant" android:textSize="13sp" />
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:layout_marginTop="80dp" android:orientation="horizontal">
                <View android:layout_width="8dp" android:layout_height="8dp" android:background="@drawable/bg_circle_surface" />
                <View android:layout_width="24dp" android:layout_height="8dp" android:layout_marginStart="8dp" android:background="@drawable/bg_progress_fill_primary" />
                <View android:layout_width="8dp" android:layout_height="8dp" android:layout_marginStart="8dp" android:background="@drawable/bg_circle_surface" />
            </LinearLayout>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnProfileContinue" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="24dp" android:background="@drawable/bg_gradient_primary" android:text="Tiếp tục" android:textAllCaps="false" android:textColor="@color/on_primary" android:textSize="16sp" android:textStyle="bold" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>