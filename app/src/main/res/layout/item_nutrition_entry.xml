<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_surface_low"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvFoodName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bún bò Huế"
            android:textColor="@color/on_surface"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvFoodMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="1 phần · 380 kcal"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvFoodFlags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Protein tốt"
            android:textColor="@color/on_secondary_container"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/btnDeleteEntry"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_circle_primary_soft"
        android:gravity="center"
        android:text="✕"
        android:textColor="@color/primary"
        android:textStyle="bold" />
</LinearLayout>
