<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="#B3FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_primary_soft"
            android:gravity="center"
            android:text="AI"
            android:textColor="@color/primary"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FocusLife AI"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gemini Powered"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/chatProgressBar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"
            android:indeterminateTint="@color/primary" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/chips"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <HorizontalScrollView
        android:id="@+id/chips"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="10dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/inputBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/chip1" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginEnd="10dp" android:background="@drawable/bg_surface_outline_round" android:gravity="center" android:paddingStart="18dp" android:paddingEnd="18dp" android:text="Gợi ý bài tập" android:textColor="@color/primary" android:textStyle="bold" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/chip2" android:layout_width="wrap_content" android:layout_height="40dp" android:layout_marginEnd="10dp" android:background="@drawable/bg_surface_outline_round" android:gravity="center" android:paddingStart="18dp" android:paddingEnd="18dp" android:text="Chế độ ăn hôm nay" android:textColor="@color/primary" android:textStyle="bold" android:clickable="true" android:focusable="true"/>
            <TextView android:id="@+id/chip3" android:layout_width="wrap_content" android:layout_height="40dp" android:background="@drawable/bg_surface_outline_round" android:gravity="center" android:paddingStart="18dp" android:paddingEnd="18dp" android:text="Làm sao để tập trung?" android:textColor="@color/primary" android:textStyle="bold" android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="0dp"
        android:layout_height="94dp"
        android:background="@drawable/bg_bottom_nav"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_surface">

            <EditText
                android:id="@+id/etMessage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#00000000"
                android:gravity="center_vertical"
                android:hint="Nhắn tin cho AI Coach..."
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:textColor="@color/on_surface"
                android:textColorHint="@color/on_surface_variant"
                android:inputType="textShortMessage|textAutoCorrect|textCapSentences"
                android:imeOptions="actionSend" />
        </FrameLayout>

        <TextView
            android:id="@+id/btnSend"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_gradient_primary"
            android:gravity="center"
            android:text="➤"
            android:textColor="@color/on_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
