    <string name="about_focuslife_chip">FocusLife Story</string>
    <string name="about_focuslife_hero_title">A companion for a more balanced life.</string>
    <string name="about_focuslife_intro">FocusLife is a mobile application that helps users balance study, health and personal growth in one place. The app supports focus sessions, movement tracking, nutrition logging, health monitoring and personal goals so every day can become a little more intentional.</string>
    <string name="about_focuslife_message_title">Life message</string>
    <string name="about_focuslife_message_body">FocusLife is built around a simple message: live mindfully, improve a little every day, and create meaningful progress through small consistent actions. When you take care of your focus, your body and your routines, you take better care of your future.</string>
    <string name="about_focuslife_team_title">Project team</string>
