<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollGoal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/bottomGoalBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:padding="28dp">

                <View
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="top|end"
                    android:alpha="0.16"
                    android:background="@drawable/bg_circle_primary_soft" />

                <View
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="bottom|start"
                    android:alpha="0.12"
                    android:background="@drawable/bg_circle_secondary_soft" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="108dp"
                        android:layout_height="108dp"
                        android:background="@drawable/bg_card_surface_high"
                        android:padding="10dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:contentDescription="@string/app_name"
                            android:scaleType="centerCrop"
                            android:src="@drawable/app_brand_logo" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Chọn 1 hoặc nhiều mục tiêu"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mục tiêu chính&#10;của bạn là gì?"
                    android:textColor="@color/on_surface"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Bạn có thể chọn một hoặc nhiều mục tiêu. Chúng tôi sẽ dùng nó để cá nhân hóa trải nghiệm trước khi vào đăng nhập."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="15sp" />

                <LinearLayout
                    android:id="@+id/cardGoalFocus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="6dp"
                    android:animateLayoutChanges="true"
                    android:background="@drawable/bg_goal_card_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_primary_soft"
                        android:gravity="center"
                        android:text="◎"
                        android:textColor="@color/primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tập trung &amp; Học tập"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="DEEP WORK"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/goalCheckFocus"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:alpha="0"
                        android:background="@drawable/bg_circle_primary"
                        android:gravity="center"
                        android:text="✓"
                        android:textColor="@color/on_primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardGoalHealth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp"
                    android:animateLayoutChanges="true"
                    android:background="@drawable/bg_goal_card_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_tertiary_soft"
                        android:gravity="center"
                        android:text="♥"
                        android:textColor="@color/tertiary"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cải thiện sức khỏe"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="HEALTH FIRST"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/goalCheckHealth"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:alpha="0"
                        android:background="@drawable/bg_circle_primary"
                        android:gravity="center"
                        android:text="✓"
                        android:textColor="@color/on_primary"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardGoalAll"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="16dp"
                    android:animateLayoutChanges="true"
                    android:background="@drawable/bg_goal_card_unselected"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_card_surface_low"
                        android:gravity="center"
                        android:text="∞"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cân bằng toàn diện"
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="HOLISTIC LIFE"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/goalCheckAll"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:alpha="0"
                        android:background="@drawable/bg_circle_primary"
                        android:gravity="center"
                        android:text="✓"
                        android:textColor="@color/on_primary"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomGoalBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingTop="14dp"
        android:paddingEnd="24dp"
        android:paddingBottom="22dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoalSkip"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:text="Lướt qua"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            app:backgroundTint="@color/surface_container_low"
            app:cornerRadius="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoalContinue"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:text="Tiếp tục"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="22dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
