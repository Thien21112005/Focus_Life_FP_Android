<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvFocusEditorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo task mới"
            android:textColor="@color/on_surface"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Lưu task lên Firebase với các field cần cho schedule, priority và Pomodoro."
            android:textColor="@color/on_surface_variant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="18dp">

            <EditText
                android:id="@+id/etFocusTaskTitle"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_input_surface"
                android:hint="Tên task"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/on_surface" />

            <EditText
                android:id="@+id/etFocusTaskDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_surface"
                android:gravity="top"
                android:hint="Mô tả chi tiết"
                android:padding="16dp"
                android:textColor="@color/on_surface" />

            <EditText
                android:id="@+id/etFocusTaskCategory"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_surface"
                android:hint="Category (ví dụ: Design, Study, Work)"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/on_surface" />

            <EditText
                android:id="@+id/etFocusTaskPriority"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_surface"
                android:hint="Priority: low / medium / high"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/on_surface" />

            <EditText
                android:id="@+id/etFocusTaskPomodoros"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_input_surface"
                android:hint="Số Pomodoro dự kiến"
                android:inputType="number"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/on_surface" />

            <LinearLayout
                android:id="@+id/cardFocusTaskStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_surface_low"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bắt đầu"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFocusTaskStartValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardFocusTaskDue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_surface_low"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Deadline"
                    android:textColor="@color/on_surface"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFocusTaskDueValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/primary" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelTask"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Hủy" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveTask"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Lưu task" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDeleteTaskDraft"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Xóa task này" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>