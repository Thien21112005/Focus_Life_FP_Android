<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="118dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lịch sử"
                    android:textColor="@color/on_surface"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLifetimeSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tổng hợp toàn bộ dữ liệu từ trước đến nay"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnRefreshLifetimeHistory"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_card_surface_low"
                android:gravity="center"
                android:text="Làm mới"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QUÃNG ĐƯỜNG ĐÃ CHẠY"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLifetimeDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="0 km"
                android:textColor="@color/on_surface"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Tổng từ các phiên chạy đã lưu"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="118dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BƯỚC CHÂN"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLifetimeSteps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="0 bước"
                    android:textColor="@color/on_surface"
                    android:textSize="25sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Space android:layout_width="12dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="118dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TẬP TRUNG"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLifetimeFocus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="0 phút"
                    android:textColor="@color/on_surface"
                    android:textSize="25sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="118dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NƯỚC ĐÃ UỐNG"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLifetimeWater"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="0 ly"
                    android:textColor="@color/on_surface"
                    android:textSize="25sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Space android:layout_width="12dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="118dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_white"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HOẠT ĐỘNG APP"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLifetimeAppUsage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="0 phút"
                    android:textColor="@color/on_surface"
                    android:textSize="25sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
