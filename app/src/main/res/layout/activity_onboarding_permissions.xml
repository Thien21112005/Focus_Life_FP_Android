                <LinearLayout android:id="@+id/cardPermissionNotification" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_glass_panel" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground" android:gravity="center_vertical" android:orientation="horizontal" android:padding="20dp">
                    <TextView android:layout_width="48dp" android:layout_height="48dp" android:background="@drawable/bg_circle_secondary_soft" android:gravity="center" android:text="🔔" android:textColor="@color/secondary" android:textSize="18sp" />
